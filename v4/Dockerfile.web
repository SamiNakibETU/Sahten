FROM python:3.11-slim AS base
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app/backend

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libpq-dev curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Contexte de build = racine du repo (Railway clone tout le dépôt).
# Chemins v4/... pour que ça marche avec dockerfilePath = "v4/Dockerfile.web".
COPY v4/pyproject.toml ./
RUN pip install --upgrade pip && pip install -e .

COPY v4/backend ./backend
COPY v4/worker ./worker
COPY v4/scripts ./scripts
COPY v4/infra ./infra

RUN chmod +x /app/scripts/docker_entrypoint.sh

EXPOSE 8000
# Entrypoint : auto-migration alembic puis uvicorn. PYTHONPATH=/app/backend (ENV).
CMD ["/app/scripts/docker_entrypoint.sh"]
