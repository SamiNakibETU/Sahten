FROM python:3.11-slim AS base
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app/backend

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libpq-dev curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Contexte de build = racine du repo (Railway clone tout le dépôt).
# Chemins v4/... pour que ça marche avec dockerfilePath = "v4/Dockerfile.web".
COPY v4/pyproject.toml ./
RUN pip install --upgrade pip && pip install -e .

COPY v4/backend ./backend
COPY v4/worker ./worker
COPY v4/scripts ./scripts
COPY v4/infra ./infra

EXPOSE 8000
# main.py utilise `from app...` : il faut PYTHONPATH=/app/backend (voir ENV ci-dessus).
# Railway fournit $PORT ; sinon 8000 en local.
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000} --proxy-headers"]
