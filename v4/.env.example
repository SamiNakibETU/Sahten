# =====================================================================
# Sahteïn v4 — environnement
# =====================================================================
APP_ENV=local                          # local | staging | production
LOG_LEVEL=INFO

# --- Base de données -------------------------------------------------
# Postgres + pgvector (Railway en prod, docker-compose en local)
DATABASE_URL=postgresql+asyncpg://sahten:sahten@localhost:5432/sahten

# --- Cache / queue ---------------------------------------------------
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE=sahten_ingest

# --- LLM (génération + analyse) -------------------------------------
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1
LLM_TEMPERATURE=0.2

# --- Embeddings ------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# --- Reranker (Cohere principal, fallback local) --------------------
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0
ENABLE_LOCAL_RERANK_FALLBACK=true
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- WhiteBeard / OLJ CMS -------------------------------------------
OLJ_API_BASE=https://api.lorientlejour.com/cms
OLJ_API_KEY=
WEBHOOK_SECRET=

# --- RAG -------------------------------------------------------------
RAG_HYBRID_TOP_K_VECTOR=50
RAG_HYBRID_TOP_K_LEXICAL=50
RAG_RERANK_TOP_K=8
RAG_MIN_RERANK_SCORE=0.20
RAG_RRF_K=60
