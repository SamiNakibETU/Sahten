# Variables d'environnement (exemple)

# Application
DEBUG=false

# LLM Provider (openai, anthropic, or mock for testing)
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# API Keys (optional - only needed if using real LLM)
# OPENAI_API_KEY=sk-...
# Groq (inférence rapide, API compatible OpenAI) : https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

# ============================================================
# Analytics / traces (Upstash Redis — API REST, pas redis://)
# ============================================================
# Depuis https://console.upstash.com → ta base → REST API :
#   UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
#   UPSTASH_REDIS_REST_TOKEN=AXX...
# Ne pas mettre REDIS_URL Railway (redis://…) à la place : incompatible avec ce client.

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# CMS Webhook Integration (WhiteBeard)
# ============================================================

# Webhook secret for HMAC signature validation
# Generate with: python -c "import uuid; print(uuid.uuid4())"
WEBHOOK_SECRET=your-webhook-secret-here

# OLJ API Configuration (for fetching recipe content)
OLJ_API_KEY=your-olj-api-key-here
OLJ_API_BASE=https://api.lorientlejour.com/cms

# Auto-enrich recipes on webhook reception
AUTO_ENRICH_ON_WEBHOOK=true
